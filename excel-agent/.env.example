# Azure App Registration (Device Code Flow — sem senha no .env)
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=rsgovbr.onmicrosoft.com

# SharePoint / OneDrive
# Rode: GET https://graph.microsoft.com/v1.0/me/drive
SHAREPOINT_DRIVE_ID=b!xxxxxxxxxxxxxxxxxxxxxxxxx
# Rode: GET https://graph.microsoft.com/v1.0/me/drive/root:/Documents/UrgenciaRenal - 2026.xlsx
WORKBOOK_ITEM_ID=01XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
WORKBOOK_TABLE_NAME=
WORKBOOK_KEY_COLUMN=

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# E-mail (SMTP) — opcional
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Monitoring
MONITOR_INTERVAL_SECONDS=300
DATA_DIR=./data
TOKEN_CACHE_PATH=./data/token_cache.json
